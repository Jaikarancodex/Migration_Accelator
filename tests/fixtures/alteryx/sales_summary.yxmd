      <Properties>
        <Configuration>
          <File>legacy.sales.customers</File>
        </Configuration>
        <Annotation>
          <AnnotationText>Customer dimension</AnnotationText>
        </Annotation>
      </Properties>
    </Node>
    <Node ToolID="6">
      <GuiSettings Plugin="AlteryxBasePluginsGui.Join.Join">
        <Position x="438" y="102" />
      </GuiSettings>
      <Properties>
        <Configuration>
          <JoinInfo connection="Left">
            <Field field="CustomerID" />
          </JoinInfo>
          <JoinInfo connection="Right">
            <Field field="CustomerID" />
          </JoinInfo>
        </Configuration>
        <Annotation>
          <AnnotationText>Join sales to customers</AnnotationText>
        </Annotation>
      </Properties>
    </Node>
    <Node ToolID="7">
      <GuiSettings Plugin="AlteryxBasePluginsGui.Summarize.Summarize">
        <Position x="534" y="102" />
      </GuiSettings>
      <Properties>
        <Configuration>
          <SummarizeFields>
            <SummarizeField field="CustomerID" action="GroupBy" rename="CustomerID" />
            <SummarizeField field="Region" action="GroupBy" rename="Region" />
            <SummarizeField field="LineTotal" action="Sum" rename="TotalSales" />
            <SummarizeField field="LineTotal" action="Count" rename="TransactionCount" />
          </SummarizeFields>
        </Configuration>
        <Annotation>
          <AnnotationText>Aggregate sales by customer and region</AnnotationText>
        </Annotation>
      </Properties>

      <Properties>
        <Configuration>
          <File>legacy.sales.sales_raw</File>
        </Configuration>
        <Annotation>
          <AnnotationText>Raw sales transactions</AnnotationText>
        </Annotation>
      </Properties>
    </Node>
    <Node ToolID="2">
      <GuiSettings Plugin="AlteryxBasePluginsGui.AlteryxSelect.AlteryxSelect">
        <Position x="150" y="54" />
      </GuiSettings>
      <Properties>
        <Configuration>
          <SelectFields>
            <SelectField field="CustomerID" selected="True" type="Int32" />
            <SelectField field="Amount" selected="True" rename="Amount" type="Double" />
            <SelectField field="Quantity" selected="True" type="Int32" />
            <SelectField field="Notes" selected="False" />
          </SelectFields>
        </Configuration>
        <Annotation>
          <AnnotationText>Drop Notes column</AnnotationText>
        </Annotation>
      </Properties>
    </Node>
    <Node ToolID="3">
      <GuiSettings Plugin="AlteryxBasePluginsGui.Filter.Filter">
        <Position x="246" y="54" />
      </GuiSettings>
      <Properties>
        <Configuration>
          <Expression>[Amount] &gt; 0</Expression>
        </Configuration>
        <Annotation>
          <AnnotationText>Drop non-positive amounts</AnnotationText>
        </Annotation>
      </Properties>
    </Node>
    <Node ToolID="4">
      <GuiSettings Plugin="AlteryxBasePluginsGui.Formula.Formula">
        <Position x="342" y="54" />
      </GuiSettings>
      <Properties>
        <Configuration>
          <FormulaFields>
            <FormulaField field="LineTotal" expression="[Amount] * [Quantity]" type="Double" />
          </FormulaFields>
        </Configuration>
        <Annotation>
          <AnnotationText>Compute line total</AnnotationText>
        </Annotation>
      </Properties>
    </Node>
    <Node ToolID="5">
      <GuiSettings Plugin="AlteryxBasePluginsGui.DbFileInput.DbFileInput">
        <Position x="54" y="150" />
